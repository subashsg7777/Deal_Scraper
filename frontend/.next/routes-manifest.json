      "regex": "^/best_games_2025(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/best_games_2025(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/blogs",
      "regex": "^/blogs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blogs(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/faq",
      "regex": "^/faq(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faq(?:/)?$"
    },
    {
      "page": "/Game",
      "regex": "^/Game(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Game(?:/)?$"
    },
    {
      "page": "/Home",
      "regex": "^/Home(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Home(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/PrivacyPolicy",
      "regex": "^/PrivacyPolicy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/PrivacyPolicy(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
